# Copy this file to .env and fill in your values
# Never commit .env to version control

# ============================================
# Data Source Selection
# ============================================
# Options: "twelvedata" (free, default) or "oanda" (requires live account)
DATA_SOURCE=twelvedata

# ============================================
# Twelve Data API (free tier: 800 requests/day)
# ============================================
# Get your API key at: https://twelvedata.com/register
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# ============================================
# OANDA API (for future use, requires live account)
# ============================================
# OANDA_API_TOKEN=your_oanda_api_token_here
# OANDA_ACCOUNT_ID=your_oanda_account_id_here
# OANDA_ENVIRONMENT=practice

# ============================================
# Google Gemini API (for chart visual analysis)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Trading Configuration
# ============================================
TRADING_MODE=paper

# ============================================
# Notification Settings (optional)
# ============================================

# --- Email (SMTP) ---
# Gmail example: smtp_host=smtp.gmail.com, smtp_port=587
# Gmail requires "App Password" (not regular password)
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com

# --- Discord ---
DISCORD_WEBHOOK_URL=

# --- LINE Messaging API ---
# 1. LINE Developers (https://developers.line.biz/) でMessaging APIチャネル作成
# 2. Channel Access Token（長期）を発行
# 3. Your User ID をチャネル基本設定から取得
# 4. 作成されたLINE公式アカウントを友だち追加
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# --- Image Hosting (for LINE chart images) ---
# https://api.imgbb.com/ で無料APIキーを取得（登録不要でも可）
IMGBB_API_KEY=
