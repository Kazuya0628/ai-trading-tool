# Copy this file to .env and fill in your values
# Never commit .env to version control

# ============================================
# IG Securities API Configuration
# ============================================
IG_API_KEY=your_ig_api_key_here
IG_USERNAME=your_ig_username_here
IG_PASSWORD=your_ig_password_here
IG_ACC_TYPE=DEMO
IG_ACC_NUMBER=your_account_number_here

# ============================================
# Google Gemini API (for chart visual analysis)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Trading Configuration
# ============================================
TRADING_MODE=paper
DEFAULT_CURRENCY_PAIR=USD/JPY
DEFAULT_LOT_SIZE=1.0
MAX_POSITION_SIZE=10.0
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=5.0

# ============================================
# Notification Settings (optional)
# ============================================
DISCORD_WEBHOOK_URL=
LINE_NOTIFY_TOKEN=
